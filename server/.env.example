# ─────────────────────────────────────────────────────────────
# AuthKit Pro — Server environment template
# Copy to `.env` and fill in real values. Never commit `.env`.
# ─────────────────────────────────────────────────────────────

# Runtime
NODE_ENV=development
PORT=4000
# Comma-separated list of allowed CORS origins
CORS_ORIGINS=http://localhost:5173

# Database (PostgreSQL)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/authkit?schema=public

# JWT secrets — generate strong random values, e.g.:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
JWT_ACCESS_SECRET=change_me_access_secret
JWT_REFRESH_SECRET=change_me_refresh_secret

# Token lifetimes
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL_DAYS=30

# Cookie config
COOKIE_DOMAIN=localhost
COOKIE_SECURE=false

# Public URL of the frontend (used to build links in emails)
APP_URL=http://localhost:5173

# Single-use token lifetimes
EMAIL_VERIFICATION_TTL_HOURS=24
PASSWORD_RESET_TTL_MINUTES=30

# Email delivery — leave SMTP_HOST blank to log emails to the console (dev).
EMAIL_FROM=AuthKit Pro <no-reply@authkit.local>
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
