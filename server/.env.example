# ─────────────────────────────────────────────────────────────
# AuthKit Pro — Server environment template
# Copy to `.env` and fill in real values. Never commit `.env`.
# ─────────────────────────────────────────────────────────────

# Runtime
NODE_ENV=development
PORT=4000
# Comma-separated list of allowed CORS origins
CORS_ORIGINS=http://localhost:5173

# Database (PostgreSQL)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/authkit?schema=public

# JWT secrets — generate strong random values, e.g.:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
JWT_ACCESS_SECRET=change_me_access_secret
JWT_REFRESH_SECRET=change_me_refresh_secret

# Base64-encoded 32-byte key encrypting 2FA secrets at rest. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
ENCRYPTION_KEY=change_me_base64_32_byte_key

# Token lifetimes
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL_DAYS=30

# Cookie config
COOKIE_DOMAIN=localhost
COOKIE_SECURE=false

# Public URL of the frontend (used to build links in emails)
APP_URL=http://localhost:5173

# Serve interactive API docs (Swagger UI) at /api/v1/docs. Set false to disable.
API_DOCS_ENABLED=true

# Reject passwords found in known breaches (Have I Been Pwned). Set false to disable.
HIBP_ENABLED=true

# CAPTCHA on register/login/forgot/passwordless. Off by default. When enabled,
# the client must send the token via the X-Captcha-Token header (or captchaToken
# body field). Provider: turnstile | hcaptcha | recaptcha.
CAPTCHA_ENABLED=false
CAPTCHA_PROVIDER=turnstile
CAPTCHA_SECRET=

# Single-use token lifetimes
EMAIL_VERIFICATION_TTL_HOURS=24
PASSWORD_RESET_TTL_MINUTES=30

# Two-factor authentication
TOTP_ISSUER=AuthKit Pro
TRUSTED_DEVICE_TTL_DAYS=30

# WebAuthn / passkeys. RP ID = registrable domain (no scheme/port); ORIGIN = full
# frontend origin. In production these must match your real domain.
WEBAUTHN_RP_ID=localhost
WEBAUTHN_RP_NAME=AuthKit Pro
WEBAUTHN_ORIGIN=http://localhost:5173

# OAuth — public URL of THIS API (used to build provider redirect URIs).
# Redirect URI to register with each provider:
#   {SERVER_PUBLIC_URL}/api/v1/auth/oauth/{google|github}/callback
SERVER_PUBLIC_URL=http://localhost:4000
# Leave a provider's pair blank to disable it.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# Email delivery — leave SMTP_HOST blank to log emails to the console (dev).
EMAIL_FROM=AuthKit Pro <no-reply@authkit.local>
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
