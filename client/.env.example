# AuthKit Pro — Client environment template
# Vite only exposes variables prefixed with VITE_ to the browser.

# Base path for API requests. In development the Vite dev server proxies
# /api to the backend (see vite.config.ts), so this can stay as-is.
VITE_API_BASE_URL=/api/v1

# Cloudflare Turnstile CAPTCHA site key. Leave blank to hide the CAPTCHA widget
# (matches the server, where CAPTCHA is off unless enabled). Pair with the
# server's CAPTCHA_ENABLED / CAPTCHA_SECRET.
VITE_TURNSTILE_SITE_KEY=
