# ─────────────────────────────────────────────────────────────
# AuthKit Pro — Docker Compose environment template
# Copy to `.env` (repo root) for `docker compose`. Never commit `.env`.
# ─────────────────────────────────────────────────────────────

# PostgreSQL
POSTGRES_USER=authkit
POSTGRES_PASSWORD=authkit
POSTGRES_DB=authkit
POSTGRES_PORT=5432

# Redis
REDIS_PORT=6379

# Published host ports
SERVER_PORT=4000
CLIENT_PORT=8080

# JWT secrets — REQUIRED. Generate with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=

# Frontend origin(s) allowed by CORS (comma-separated)
CORS_ORIGINS=http://localhost:8080

# Cookie settings (set COOKIE_SECURE=true behind HTTPS in production)
COOKIE_DOMAIN=localhost
COOKIE_SECURE=false
